// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model Transactions {
  id          String             @id @default(cuid())
  amount      Decimal
  title       String 
  description String? 
  type        TransactionType
  date        DateTime           @default(now())

  // relasi ke kategori
  categoryId  String
  category    Categories        @relation(fields: [categoryId], references: [id]) 

  // relasi ke user
  userId      String
  user        Users             @relation(fields: [userId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId,date])
}

model Categories {
  id          String     @id @default(cuid())
  name        String
  normalizeName String
  type        CategoryType  
  userId      String

  // relasi ke user
  user          Users             @relation(fields: [userId], references: [id])
  transactions  Transactions[]
  budgetCategory   BudgetCategory[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Constraint: Nama kategori unik per-user, bukan unik secara global
  // Name boleh duplikat (User A punya "Makan", User B punya "Makan").
  // UserId boleh duplikat (User A punya "Makan", User A punya "Transport").
  // PASANGAN keduanya tidak boleh duplikat (User A tidak boleh punya dua kategori "Makan").
  @@unique([normalizeName, userId])
}

model Users {
  id            String          @id @default(cuid())
  fullname      String
  email         String          @unique
  password      String     
  image         String?

  budgets       Budgets[]          
  transactions  Transactions[]
  categories    Categories[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Budgets {
  id            String          @id @default(cuid())
  userId        String
  user          Users           @relation(fields: [userId], references: [id])

  month         Int             // 1-12
  year          Int

  totalAmount   Decimal

  description   String?

  budgetCategory      BudgetCategory[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, year, month])
  @@index([userId, year, month])
}

model BudgetCategory {
  id          String       @id @default(cuid())

  budgetId    String
  budget      Budgets      @relation(fields: [budgetId], references: [id])

  categoryId  String
  category    Categories   @relation(fields: [categoryId], references: [id])

  amount      Decimal

  @@unique([budgetId, categoryId])
}

enum TransactionType {
  Income
  Expense
}

enum CategoryType {
  Income
  Expense
}