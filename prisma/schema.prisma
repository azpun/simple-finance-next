// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model Transactions {
  id          String             @id @default(cuid())
  amount      Int
  title       String 
  description String? 
  type        TransactionType
  date        DateTime        @default(now())

  // relasi ke kategori
  categoryId  String
  category    Categories        @relation(fields: [categoryId], references: [id]) 

  // relasi ke user
  userId      String
  user        Users             @relation(fields: [userId], references: [id])

  createdAt   DateTime        @default(now())
}

model Categories {
  id          String     @id @default(cuid())
  name        String  
  transactions Transactions[]

  // relasi ke user
  userId      String
  user        Users             @relation(fields: [userId], references: [id])

  // Constraint: Nama kategori unik per-user, bukan unik secara global
  // Name boleh duplikat (User A punya "Makan", User B punya "Makan").
  // UserId boleh duplikat (User A punya "Makan", User A punya "Transport").
  // PASANGAN keduanya tidak boleh duplikat (User A tidak boleh punya dua kategori "Makan").
  @@unique([name, userId])
}

model Users {
  id            String          @id @default(cuid())
  fullname      String
  email         String          @unique
  password      String          
  budgets       Budgets[]          
  transactions  Transactions[]
  categories    Categories[]
}

model Budgets {
  id            String          @id @default(cuid())
  userId        String
  user          Users           @relation(fields: [userId], references: [id])

  amount        Int
  month         Int
  year          Int

  @@unique([userId, year, month])
}

enum TransactionType {
  INCOME
  EXPENSE
}